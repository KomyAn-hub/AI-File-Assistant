# AI File Assistant — copy this file to .env

# ── Security note ─────────────────────────────────────────────────────────────
# The Anthropic API key is NEVER stored here.
# It lives in the Cloudflare Worker as a secret (server-side only).
# See proxy/README.md for setup instructions.

# ── Proxy URL ─────────────────────────────────────────────────────────────────
# After deploying the Cloudflare Worker, paste its URL here.
# Format: https://<worker-name>.<your-subdomain>.workers.dev/api/classify
# Without this var, the app uses the fast offline keyword classifier.
VITE_PROXY_URL=https://ai-file-assistant-proxy.YOUR_SUBDOMAIN.workers.dev/api/classify

# ── Local dev override ────────────────────────────────────────────────────────
# To test the proxy locally, run `wrangler dev` in /proxy and set:
# VITE_PROXY_URL=http://localhost:8787/api/classify
